{
  "name": "@aklinker1/viteshot",
  "description": "Generate store screenshots and promo images with code, powered by Vite",
  "version": "0.4.2",
  "type": "module",
  "packageManager": "bun@1.3.9",
  "scripts": {
    "viteshot": "bun run -d process.env.DEV:\"true\" -d process.env.COMMIT_HASH:\"'DEV'\" src/cli.ts",
    "dev": "bun viteshot dev example",
    "export": "bun viteshot export example",
    "build": "tsdown",
    "build:hash": "git rev-parse --short=7 HEAD",
    "prepack": "bun run build"
  },
  "dependencies": {
    "async-mutex": "^0.5.0",
    "natural-compare-lite": "^1.4.0",
    "p-map": "^7.0.4",
    "p-queue": "^9.1.0",
    "puppeteer-core": "^24.37.5"
  },
  "peerDependencies": {
    "vite": ">=5",
    "vue": ">=3",
    "react": ">=19",
    "react-dom": ">=19",
    "svelte": ">=5"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "svelte": {
      "optional": true
    }
  },
  "devDependencies": {
    "@aklinker1/check": "^2.2.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "latest",
    "@types/natural-compare-lite": "^1.4.2",
    "@types/react": "^19.2.14",
    "@typescript/native-preview": "^7.0.0-dev.20260223.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "oxlint": "^1.50.0",
    "prettier": "^3.8.1",
    "prettier-plugin-jsdoc": "^1.8.0",
    "publint": "^0.3.17",
    "puppeteer": "^24.37.5",
    "tailwindcss": "^4.2.2",
    "tsdown": "^0.20.3",
    "typescript": "^5"
  },
  "types": "dist/index.d.mts",
  "module": "dist/index.mjs",
  "bin": {
    "viteshot": "dist/cli.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "license": "MIT",
  "author": {
    "email": "aaronklinker1@gmail.com",
    "name": "Aaron Klinker"
  },
  "repository": {
    "url": "https://github.com/aklinker1/viteshot"
  },
  "files": [
    "dist",
    "assets"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "vite",
    "promo",
    "images",
    "screenshot",
    "generate",
    "export",
    "store"
  ]
}
